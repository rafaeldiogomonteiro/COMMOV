<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="56dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/createTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/create_task_title"
                android:textColor="@color/dashboard_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/createTaskProject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/dashboard_text_secondary"
                android:textSize="15sp" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_task_title" />

            <EditText
                android:id="@+id/taskTitleInput"
                style="@style/CreateTaskInput"
                android:inputType="textCapSentences"
                android:singleLine="true" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_user" />

            <Spinner
                android:id="@+id/taskUserInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_login_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_status" />

            <Spinner
                android:id="@+id/taskStatusInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_login_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_description" />

            <EditText
                android:id="@+id/taskDescriptionInput"
                style="@style/CreateTaskInput"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="92dp"
                android:singleLine="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CreateTaskLabelNoTop"
                        android:text="@string/create_task_estimated_end_date" />

                    <EditText
                        android:id="@+id/taskEstimatedEndDateInput"
                        style="@style/CreateTaskInput"
                        android:hint="@string/create_task_date_hint"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CreateTaskLabelNoTop"
                        android:text="@string/create_task_work_date" />

                    <EditText
                        android:id="@+id/taskWorkDateInput"
                        style="@style/CreateTaskInput"
                        android:hint="@string/create_task_date_hint"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:singleLine="true" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_actual_end_date" />

            <EditText
                android:id="@+id/taskActualEndDateInput"
                style="@style/CreateTaskInput"
                android:hint="@string/create_task_date_hint"
                android:cursorVisible="false"
                android:focusable="false"
                android:inputType="none"
                android:singleLine="true" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CreateTaskLabelNoTop"
                        android:text="@string/create_task_estimated_time" />

                    <EditText
                        android:id="@+id/taskEstimatedTimeInput"
                        style="@style/CreateTaskInput"
                        android:hint="@string/create_task_number_hint"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CreateTaskLabelNoTop"
                        android:text="@string/create_task_completion_rate" />

                    <EditText
                        android:id="@+id/taskCompletionRateInput"
                        style="@style/CreateTaskInput"
                        android:hint="@string/create_task_number_hint"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:singleLine="true" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_time_spent" />

            <EditText
                android:id="@+id/taskTimeSpentInput"
                style="@style/CreateTaskInput"
                android:hint="@string/create_task_number_hint"
                android:cursorVisible="false"
                android:focusable="false"
                android:inputType="none"
                android:singleLine="true" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_location" />

            <EditText
                android:id="@+id/taskLocationInput"
                style="@style/CreateTaskInput"
                android:inputType="textCapWords"
                android:singleLine="true" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_observation" />

            <EditText
                android:id="@+id/taskObservationInput"
                style="@style/CreateTaskInput"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="82dp"
                android:singleLine="false" />

            <TextView
                style="@style/CreateTaskLabel"
                android:text="@string/create_task_photo" />

            <EditText
                android:id="@+id/taskPhotoInput"
                style="@style/CreateTaskInput"
                android:inputType="textUri"
                android:singleLine="true" />

            <Button
                android:id="@+id/saveTaskButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_login_button"
                android:text="@string/create_task_save"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_navigation" />
</LinearLayout>
